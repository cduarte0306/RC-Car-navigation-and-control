{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug RC Car (Jetson - Remote)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/src/rc-car-nav",
      "miDebuggerServerAddress": "192.168.1.10:2345",
      "miDebuggerPath": "/opt/poky/5.0.11/sysroots/x86_64-pokysdk-linux/usr/bin/aarch64-poky-linux/aarch64-poky-linux-gdb",
      "MIMode": "gdb",
      "targetArchitecture": "arm64",                 // explicit target arch
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Run GDB Server (Jetson - Remote)",
      "stopAtEntry": true,
      "setupCommands": [
        { "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true }
      ],
      "externalConsole": false
    },
    {
      "name" : "Debug lane-detection test",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/tests/lane-detection/lane-detection.py",
      "console": "integratedTerminal"
    },
    {
      "name" : "Debug ML lane-detection test",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/tests/lane-detection/lane-detection-ml.py",
      "console": "integratedTerminal"
    },
    {
      "name" : "Debug Tensor RT lane-detection test",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/tests/tensorRT/lane-detection-tensor-rt.py",
      "console": "integratedTerminal",
      "args": ["--model", "/home/cduarte0306/repos/AnyLaneNET/lanenet.onnx", "--video", "/home/cduarte0306/repos/AnyLaneNET/src/video/video.MOV"]
    }
  ]
}
